@model FinSightPro.Web.ViewModels.BudgetListViewModel
@{
    ViewData["Title"] = "Orçamentos";
    var pt = new System.Globalization.CultureInfo("pt-PT");
}

<div class="d-flex flex-wrap justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0"><i class="fa-solid fa-piggy-bank text-success"></i> Orçamentos</h1>
    <a asp-action="Create" class="btn btn-success"><i class="fa-solid fa-plus"></i> Novo orçamento</a>
</div>

<form method="get" class="card border-0 shadow-sm mb-3">
    <div class="card-body row g-2 align-items-end">
        <div class="col-md-3">
            <label class="form-label small">Ano</label>
            <input type="number" name="year" value="@Model.Year" class="form-control" />
        </div>
        <div class="col-md-3">
            <label class="form-label small">Mês</label>
            <select name="month" class="form-select">
                @for (int m = 1; m <= 12; m++)
                {
                    if (m == Model.Month)
                    {
                        <option value="@m" selected>@(new System.Globalization.CultureInfo("pt-PT").DateTimeFormat.GetMonthName(m))</option>
                    }
                    else
                    {
                        <option value="@m">@(new System.Globalization.CultureInfo("pt-PT").DateTimeFormat.GetMonthName(m))</option>
                    }
                }
            </select>
        </div>
        <div class="col-md-3">
            <button class="btn btn-outline-success" type="submit">Filtrar</button>
        </div>
        <div class="col-md-3 text-end">
            <span class="badge bg-secondary fs-6 me-1">Total: @Model.TotalLimit.ToString("C", pt)</span>
            <span class="badge bg-danger fs-6">Gasto: @Model.TotalSpent.ToString("C", pt)</span>
        </div>
    </div>
</form>

<div class="row g-3">
    @foreach (var b in Model.Items)
    {
        var pct = (double)Math.Min(b.PercentUsed, 100m);
        var cls = b.PercentUsed >= 100 ? "bg-danger" : (b.PercentUsed >= 90 ? "bg-warning" : (b.PercentUsed >= 75 ? "bg-info" : "bg-success"));
        <div class="col-md-6 col-lg-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center gap-2 mb-2">
                        <div class="category-icon-sm" style="background-color:@b.CategoryColor"><i class="fa-solid @b.CategoryIcon"></i></div>
                        <strong>@b.CategoryName</strong>
                        <span class="ms-auto fw-bold">@b.PercentUsed%</span>
                    </div>
                    <div class="progress mb-2" style="height:.6rem">
                        <div class="progress-bar @cls" style="width:@pct.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)%"></div>
                    </div>
                    <div class="d-flex justify-content-between small text-muted">
                        <span>@b.Spent.ToString("C", pt)</span>
                        <span>de @b.MonthlyLimit.ToString("C", pt)</span>
                    </div>
                </div>
                <div class="card-footer bg-transparent d-flex justify-content-end gap-2">
                    <a asp-action="Edit" asp-route-id="@b.Id" class="btn btn-sm btn-outline-primary">Editar</a>
                    <a asp-action="Delete" asp-route-id="@b.Id" class="btn btn-sm btn-outline-danger">Eliminar</a>
                </div>
            </div>
        </div>
    }
    @if (!Model.Items.Any())
    {
        <div class="col-12">
            <div class="alert alert-info">Sem orçamentos definidos para este mês.</div>
        </div>
    }
</div>
