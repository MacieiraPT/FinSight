@model FinSightPro.Application.DTOs.BudgetDto
@{
    ViewData["Title"] = "Eliminar Orçamento";
    var pt = new System.Globalization.CultureInfo("pt-PT");
}

<div class="card border-0 shadow-sm">
    <div class="card-body">
        <h1 class="h4 text-danger"><i class="fa-solid fa-triangle-exclamation"></i> Eliminar orçamento</h1>
        <p>Tens a certeza que pretendes eliminar o orçamento de <strong>@Model.CategoryName</strong> de @Model.MonthlyLimit.ToString("C", pt) (@Model.Month/@Model.Year)?</p>
    </div>
    <div class="card-footer bg-transparent d-flex justify-content-end gap-2">
        <form asp-action="Delete" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.Id" />
            <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
            <button class="btn btn-danger" type="submit">Eliminar</button>
        </form>
    </div>
</div>
