@inject Microsoft.AspNetCore.Identity.SignInManager<FinSightPro.Domain.Entities.ApplicationUser> SignInManager
@inject Microsoft.AspNetCore.Identity.UserManager<FinSightPro.Domain.Entities.ApplicationUser> UserManager
<!DOCTYPE html>
<html lang="pt-PT" data-bs-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewData["Title"]) — FinSight Pro</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-finsight sticky-top shadow-sm">
        <div class="container-fluid">
            <a class="navbar-brand fw-bold d-flex align-items-center gap-2" asp-controller="Dashboard" asp-action="Index">
                <i class="fa-solid fa-chart-line"></i> FinSight Pro
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="mainNav">
                @if (SignInManager.IsSignedIn(User))
                {
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item"><a class="nav-link" asp-controller="Dashboard" asp-action="Index"><i class="fa-solid fa-gauge-high"></i> Dashboard</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Despesas" asp-action="Index"><i class="fa-solid fa-receipt"></i> Despesas</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Receitas" asp-action="Index"><i class="fa-solid fa-sack-dollar"></i> Receitas</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Categorias" asp-action="Index"><i class="fa-solid fa-tags"></i> Categorias</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Orcamentos" asp-action="Index"><i class="fa-solid fa-piggy-bank"></i> Orçamentos</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Relatorios" asp-action="Index"><i class="fa-solid fa-chart-pie"></i> Relatórios</a></li>
                    </ul>
                }
                <ul class="navbar-nav ms-auto align-items-lg-center">
                    <li class="nav-item me-2">
                        <button id="themeToggle" class="btn btn-outline-secondary btn-sm" type="button" title="Alternar tema">
                            <i class="fa-solid fa-moon"></i>
                        </button>
                    </li>
                    @if (SignInManager.IsSignedIn(User))
                    {
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle d-flex align-items-center" data-bs-toggle="dropdown" href="#">
                                <i class="fa-solid fa-circle-user fa-lg me-1"></i>
                                @(User.Identity?.Name)
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li><a class="dropdown-item" asp-area="Identity" asp-page="/Account/Manage/Index"><i class="fa-solid fa-user"></i> Perfil</a></li>
                                <li><hr class="dropdown-divider" /></li>
                                <li>
                                    <form asp-area="Identity" asp-page="/Account/Logout" method="post">
                                        <button type="submit" class="dropdown-item"><i class="fa-solid fa-right-from-bracket"></i> Sair</button>
                                    </form>
                                </li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item"><a class="nav-link" asp-area="Identity" asp-page="/Account/Login">Entrar</a></li>
                        <li class="nav-item"><a class="nav-link btn btn-primary text-white px-3 ms-2" asp-area="Identity" asp-page="/Account/Register">Registar</a></li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <main class="container-fluid py-4">
        @await Html.PartialAsync("_Notifications")
        @if (ViewBag.Breadcrumbs is List<(string Label, string? Url)> crumbs)
        {
            <nav aria-label="breadcrumb" class="mb-3">
                <ol class="breadcrumb">
                    @for (int i = 0; i < crumbs.Count; i++)
                    {
                        var c = crumbs[i];
                        if (c.Url != null && i < crumbs.Count - 1)
                        {
                            <li class="breadcrumb-item"><a href="@c.Url">@c.Label</a></li>
                        }
                        else
                        {
                            <li class="breadcrumb-item active" aria-current="page">@c.Label</li>
                        }
                    }
                </ol>
            </nav>
        }
        @RenderBody()
    </main>

    <footer class="footer-finsight border-top py-3 mt-5 text-center small text-muted">
        © @DateTime.UtcNow.Year FinSight Pro · feito com <i class="fa-solid fa-heart text-danger"></i> em Portugal
    </footer>

    <div class="toast-container position-fixed bottom-0 end-0 p-3" id="toastContainer"></div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
