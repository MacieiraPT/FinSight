@model FinSightPro.Application.Interfaces.MonthComparisonDto
@{
    ViewData["Title"] = "Relatórios";
    var pt = new System.Globalization.CultureInfo("pt-PT");
    var year = (int)ViewBag.Year;
    var month = (int)ViewBag.Month;
}

<div class="d-flex flex-wrap justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0"><i class="fa-solid fa-chart-pie text-warning"></i> Relatórios</h1>
    <form method="get" class="d-flex gap-2">
        <input type="number" name="year" value="@year" min="2000" max="2100" class="form-control" style="width:6rem" />
        <select name="month" class="form-select" style="width:9rem">
            @for (int m = 1; m <= 12; m++)
            {
                if (m == month)
                {
                    <option value="@m" selected>@(pt.DateTimeFormat.GetMonthName(m))</option>
                }
                else
                {
                    <option value="@m">@(pt.DateTimeFormat.GetMonthName(m))</option>
                }
            }
        </select>
        <button type="submit" class="btn btn-outline-warning"><i class="fa-solid fa-arrows-rotate"></i></button>
    </form>
</div>

<div class="d-flex justify-content-end gap-2 mb-3">
    <form asp-action="ExportarMensalCsv" method="post" class="d-inline">
        @Html.AntiForgeryToken()
        <input type="hidden" name="year" value="@year" />
        <input type="hidden" name="month" value="@month" />
        <button type="submit" class="btn btn-outline-success btn-sm"><i class="fa-solid fa-file-csv"></i> CSV</button>
    </form>
    <form asp-action="ExportarMensalExcel" method="post" class="d-inline">
        @Html.AntiForgeryToken()
        <input type="hidden" name="year" value="@year" />
        <input type="hidden" name="month" value="@month" />
        <button type="submit" class="btn btn-outline-success btn-sm"><i class="fa-solid fa-file-excel"></i> Excel</button>
    </form>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card kpi-card border-0 shadow-sm">
            <div class="card-body">
                <div class="kpi-label">Receitas</div>
                <div class="kpi-value text-success">@Model.Current.TotalIncome.ToString("C", pt)</div>
                <small class="@(Model.IncomeDeltaPercent >= 0 ? "text-success" : "text-danger")">
                    @(Model.IncomeDeltaPercent >= 0 ? "+" : "")@Model.IncomeDeltaPercent% vs mês anterior
                </small>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card kpi-card border-0 shadow-sm">
            <div class="card-body">
                <div class="kpi-label">Despesas</div>
                <div class="kpi-value text-danger">@Model.Current.TotalExpenses.ToString("C", pt)</div>
                <small class="@(Model.ExpenseDeltaPercent <= 0 ? "text-success" : "text-danger")">
                    @(Model.ExpenseDeltaPercent >= 0 ? "+" : "")@Model.ExpenseDeltaPercent% vs mês anterior
                </small>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card kpi-card border-0 shadow-sm">
            <div class="card-body">
                <div class="kpi-label">Projeção do Mês</div>
                <div class="kpi-value">@Model.Current.Projected.ToString("C", pt)</div>
                <small class="text-muted">Média diária @Model.Current.AverageDaily.ToString("C", pt) · @Model.Current.DaysElapsed/@Model.Current.DaysInMonth dias</small>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm mb-4">
    <div class="card-header bg-transparent border-0">
        <h5 class="mb-0">Despesas por Categoria — @pt.DateTimeFormat.GetMonthName(month) @year</h5>
    </div>
    <div class="table-responsive">
        <table class="table mb-0 align-middle">
            <thead class="table-light">
                <tr><th>Categoria</th><th class="text-end">Total</th><th class="text-end">% do total</th></tr>
            </thead>
            <tbody>
                @foreach (var c in Model.Current.ByCategory)
                {
                    var pct = Model.Current.TotalExpenses == 0 ? 0 : Math.Round(c.Total / Model.Current.TotalExpenses * 100m, 1);
                    <tr>
                        <td><i class="fa-solid @c.Icon" style="color:@c.Color"></i> @c.CategoryName</td>
                        <td class="text-end">@c.Total.ToString("C", pt)</td>
                        <td class="text-end">@pct%</td>
                    </tr>
                }
                @if (!Model.Current.ByCategory.Any())
                {
                    <tr><td colspan="3" class="text-center text-muted py-3">Sem dados.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-header bg-transparent border-0"><h5 class="mb-0">Comparação Mensal</h5></div>
    <div class="table-responsive">
        <table class="table mb-0">
            <thead class="table-light">
                <tr>
                    <th></th>
                    <th class="text-end">@pt.DateTimeFormat.GetMonthName(Model.Previous.Month) @Model.Previous.Year</th>
                    <th class="text-end">@pt.DateTimeFormat.GetMonthName(Model.Current.Month) @Model.Current.Year</th>
                </tr>
            </thead>
            <tbody>
                <tr><td>Receitas</td><td class="text-end">@Model.Previous.TotalIncome.ToString("C", pt)</td><td class="text-end">@Model.Current.TotalIncome.ToString("C", pt)</td></tr>
                <tr><td>Despesas</td><td class="text-end">@Model.Previous.TotalExpenses.ToString("C", pt)</td><td class="text-end">@Model.Current.TotalExpenses.ToString("C", pt)</td></tr>
                <tr class="fw-bold"><td>Saldo</td><td class="text-end">@Model.Previous.Balance.ToString("C", pt)</td><td class="text-end">@Model.Current.Balance.ToString("C", pt)</td></tr>
            </tbody>
        </table>
    </div>
</div>
