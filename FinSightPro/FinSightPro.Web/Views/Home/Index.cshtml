@{
    ViewData["Title"] = "Bem-vindo";
}
<section class="hero text-center py-5">
    <div class="container">
        <h1 class="display-4 fw-bold mb-3"><i class="fa-solid fa-chart-line text-primary"></i> FinSight Pro</h1>
        <p class="lead text-muted">Gere as suas finanças pessoais com clareza, controlo e tranquilidade.</p>
        <div class="mt-4 d-flex justify-content-center gap-2 flex-wrap">
            <a class="btn btn-primary btn-lg" asp-area="Identity" asp-page="/Account/Register">
                <i class="fa-solid fa-user-plus"></i> Criar conta
            </a>
            <a class="btn btn-outline-secondary btn-lg" asp-area="Identity" asp-page="/Account/Login">
                Já tenho conta
            </a>
        </div>
    </div>
</section>

<section class="container my-5">
    <div class="row g-4">
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body">
                    <i class="fa-solid fa-receipt fa-2x text-primary mb-2"></i>
                    <h5 class="card-title">Despesas detalhadas</h5>
                    <p class="text-muted">Categorias, métodos de pagamento, anexos e despesas recorrentes.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body">
                    <i class="fa-solid fa-piggy-bank fa-2x text-success mb-2"></i>
                    <h5 class="card-title">Orçamentos inteligentes</h5>
                    <p class="text-muted">Define limites por categoria e recebe alertas automáticos.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body">
                    <i class="fa-solid fa-chart-pie fa-2x text-warning mb-2"></i>
                    <h5 class="card-title">Análise visual</h5>
                    <p class="text-muted">Gráficos, tendências mensais e exportação em CSV/Excel.</p>
                </div>
            </div>
        </div>
    </div>
</section>
