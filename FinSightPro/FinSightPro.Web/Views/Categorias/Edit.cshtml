@model FinSightPro.Web.ViewModels.CategoryFormViewModel
@{ ViewData["Title"] = "Editar Categoria"; }

<h1 class="h3 mb-4"><i class="fa-solid fa-pen-to-square text-primary"></i> Editar Categoria</h1>
<form asp-action="Edit" method="post" class="card border-0 shadow-sm">
    <div class="card-body">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <partial name="_Form" model="Model" />
    </div>
    <div class="card-footer bg-transparent d-flex justify-content-end gap-2">
        <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
        <button class="btn btn-primary" type="submit">Guardar alterações</button>
    </div>
</form>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
