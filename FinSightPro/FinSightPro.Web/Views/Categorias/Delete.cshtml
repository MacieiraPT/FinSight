@model FinSightPro.Application.DTOs.CategoryDto
@{ ViewData["Title"] = "Eliminar Categoria"; }

<div class="card border-0 shadow-sm">
    <div class="card-body">
        <h1 class="h4 text-danger mb-3"><i class="fa-solid fa-triangle-exclamation"></i> Eliminar categoria</h1>
        <p>Tens a certeza que pretendes eliminar a categoria <strong>@Model.Name</strong>?</p>
        <p class="small text-muted">Categorias com despesas associadas não podem ser eliminadas.</p>
    </div>
    <div class="card-footer bg-transparent d-flex justify-content-end gap-2">
        <form asp-action="Delete" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.Id" />
            <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
            <button type="submit" class="btn btn-danger">Eliminar</button>
        </form>
    </div>
</div>
