@model List<FinSightPro.Application.DTOs.CategoryDto>
@{ ViewData["Title"] = "Categorias"; }

<div class="d-flex flex-wrap justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0"><i class="fa-solid fa-tags text-primary"></i> Categorias</h1>
    <div class="d-flex gap-2">
        <form asp-action="SeedDefault" method="post">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-outline-secondary"><i class="fa-solid fa-wand-magic-sparkles"></i> Categorias por defeito</button>
        </form>
        <a asp-action="Create" class="btn btn-primary"><i class="fa-solid fa-plus"></i> Nova categoria</a>
    </div>
</div>

<div class="row g-3">
    @foreach (var c in Model)
    {
        <div class="col-md-4 col-lg-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="category-icon" style="background-color:@c.Color">
                        <i class="fa-solid @c.Icon"></i>
                    </div>
                    <div class="flex-grow-1">
                        <div class="fw-semibold">@c.Name</div>
                        @if (!string.IsNullOrEmpty(c.ParentCategoryName))
                        {
                            <small class="text-muted">↳ @c.ParentCategoryName</small>
                        }
                    </div>
                    <div class="dropdown">
                        <button class="btn btn-sm btn-outline-secondary" data-bs-toggle="dropdown"><i class="fa-solid fa-ellipsis-vertical"></i></button>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li><a class="dropdown-item" asp-action="Edit" asp-route-id="@c.Id">Editar</a></li>
                            <li><a class="dropdown-item" asp-action="Details" asp-route-id="@c.Id">Detalhes</a></li>
                            <li><hr class="dropdown-divider" /></li>
                            <li><a class="dropdown-item text-danger" asp-action="Delete" asp-route-id="@c.Id">Eliminar</a></li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    }
    @if (!Model.Any())
    {
        <div class="col-12">
            <div class="alert alert-info">Ainda não tens categorias. Clica em <strong>Categorias por defeito</strong> para começar.</div>
        </div>
    }
</div>
