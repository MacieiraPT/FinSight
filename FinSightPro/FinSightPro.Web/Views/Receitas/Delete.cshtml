@model FinSightPro.Application.DTOs.IncomeDto
@{
    ViewData["Title"] = "Eliminar Receita";
    var pt = new System.Globalization.CultureInfo("pt-PT");
}

<div class="card border-0 shadow-sm">
    <div class="card-body">
        <h1 class="h4 mb-3 text-danger"><i class="fa-solid fa-triangle-exclamation"></i> Eliminar receita</h1>
        <p>Tens a certeza que pretendes eliminar a receita <strong>@Model.Description</strong> de @Model.Amount.ToString("C", pt)?</p>
    </div>
    <div class="card-footer bg-transparent d-flex justify-content-end gap-2">
        <form asp-action="Delete" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.Id" />
            <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
            <button type="submit" class="btn btn-danger">Eliminar</button>
        </form>
    </div>
</div>
