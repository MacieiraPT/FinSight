@model FinSightPro.Web.ViewModels.IncomeFormViewModel
@{ ViewData["Title"] = "Nova Receita"; }

<h1 class="h3 mb-4"><i class="fa-solid fa-circle-plus text-success"></i> Nova Receita</h1>
<form asp-action="Create" method="post" class="card border-0 shadow-sm">
    <div class="card-body">
        @Html.AntiForgeryToken()
        <partial name="_Form" model="Model" />
    </div>
    <div class="card-footer bg-transparent d-flex justify-content-end gap-2">
        <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
        <button class="btn btn-success" type="submit"><i class="fa-solid fa-floppy-disk"></i> Guardar</button>
    </div>
</form>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
