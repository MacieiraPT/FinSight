@model FinSightPro.Web.ViewModels.IncomeFormViewModel

<div class="row g-3">
    <div class="col-md-8">
        <label asp-for="Description" class="form-label"></label>
        <input asp-for="Description" class="form-control" />
        <span asp-validation-for="Description" class="text-danger small"></span>
    </div>
    <div class="col-md-4">
        <label asp-for="Amount" class="form-label"></label>
        <input asp-for="Amount" type="number" step="0.01" class="form-control" />
    </div>
    <div class="col-md-4">
        <label asp-for="Date" class="form-label"></label>
        <input asp-for="Date" type="date" class="form-control" value="@Model.Date.ToString("yyyy-MM-dd")" />
    </div>
    <div class="col-md-4">
        <label asp-for="CategoryId" class="form-label"></label>
        <select asp-for="CategoryId" class="form-select">
            <option value="">— sem categoria —</option>
            @foreach (var c in Model.Categories)
            {
                <option value="@c.Id">@c.Name</option>
            }
        </select>
    </div>
    <div class="col-md-4">
        <div class="form-check mt-4">
            <input asp-for="IsFixed" class="form-check-input" />
            <label class="form-check-label" asp-for="IsFixed"></label>
        </div>
        <div class="form-check">
            <input asp-for="IsRecurring" class="form-check-input" />
            <label class="form-check-label" asp-for="IsRecurring"></label>
        </div>
    </div>
    <div class="col-md-4 recurring-only">
        <label asp-for="RecurrenceType" class="form-label"></label>
        <select asp-for="RecurrenceType" class="form-select">
            @foreach (var r in Enum.GetValues<FinSightPro.Domain.Enums.RecurrenceType>())
            {
                if (r != FinSightPro.Domain.Enums.RecurrenceType.None)
                {
                    <option value="@r">@r</option>
                }
            }
        </select>
    </div>
    <div class="col-md-4 recurring-only">
        <label asp-for="RecurrenceEndDate" class="form-label"></label>
        <input asp-for="RecurrenceEndDate" type="date" class="form-control" />
    </div>
    <div class="col-md-12">
        <label asp-for="Notes" class="form-label"></label>
        <textarea asp-for="Notes" class="form-control" rows="2"></textarea>
    </div>
</div>
