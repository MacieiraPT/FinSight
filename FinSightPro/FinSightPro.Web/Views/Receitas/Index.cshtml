@model FinSightPro.Web.ViewModels.IncomeListViewModel
@{
    ViewData["Title"] = "Receitas";
    var pt = new System.Globalization.CultureInfo("pt-PT");
}

<div class="d-flex flex-wrap justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0"><i class="fa-solid fa-sack-dollar text-success"></i> Receitas</h1>
    <a class="btn btn-success" asp-action="Create"><i class="fa-solid fa-plus"></i> Nova receita</a>
</div>

<form method="get" class="card border-0 shadow-sm mb-3">
    <div class="card-body row g-2 align-items-end">
        <div class="col-md-3">
            <label class="form-label small">Ano</label>
            <input type="number" name="year" value="@Model.Year" class="form-control" />
        </div>
        <div class="col-md-3">
            <label class="form-label small">Mês</label>
            <select name="month" class="form-select">
                <option value="">Todos</option>
                @for (int m = 1; m <= 12; m++)
                {
                    if (Model.Month == m)
                    {
                        <option value="@m" selected>@(new System.Globalization.CultureInfo("pt-PT").DateTimeFormat.GetMonthName(m))</option>
                    }
                    else
                    {
                        <option value="@m">@(new System.Globalization.CultureInfo("pt-PT").DateTimeFormat.GetMonthName(m))</option>
                    }
                }
            </select>
        </div>
        <div class="col-md-3 d-flex gap-2">
            <button class="btn btn-outline-success" type="submit"><i class="fa-solid fa-filter"></i> Filtrar</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Limpar</a>
        </div>
        <div class="col-md-3 text-end">
            <span class="badge bg-success fs-6">Total: @Model.Total.ToString("C", pt)</span>
        </div>
    </div>
</form>

<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover mb-0 align-middle">
            <thead class="table-light">
                <tr>
                    <th>Data</th>
                    <th>Descrição</th>
                    <th>Categoria</th>
                    <th>Tipo</th>
                    <th class="text-end">Valor</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var i in Model.Items)
                {
                    <tr>
                        <td>@i.Date.ToString("yyyy-MM-dd")</td>
                        <td>
                            @i.Description
                            @if (i.IsRecurring) { <span class="badge bg-info ms-1"><i class="fa-solid fa-repeat"></i></span> }
                        </td>
                        <td>@i.CategoryName</td>
                        <td>
                            @if (i.IsFixed) { <span class="badge bg-secondary">Fixo</span> }
                            else { <span class="badge bg-warning text-dark">Variável</span> }
                        </td>
                        <td class="text-end fw-semibold text-success">@i.Amount.ToString("C", pt)</td>
                        <td class="text-end">
                            <a asp-action="Edit" asp-route-id="@i.Id" class="btn btn-sm btn-outline-primary"><i class="fa-solid fa-pen"></i></a>
                            <a asp-action="Delete" asp-route-id="@i.Id" class="btn btn-sm btn-outline-danger"><i class="fa-solid fa-trash"></i></a>
                        </td>
                    </tr>
                }
                @if (!Model.Items.Any())
                {
                    <tr><td colspan="6" class="text-center text-muted py-4">Sem receitas registadas.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
