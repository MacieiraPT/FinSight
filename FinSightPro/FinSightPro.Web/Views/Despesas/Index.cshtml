@model FinSightPro.Web.ViewModels.ExpenseListViewModel
@{
    ViewData["Title"] = "Despesas";
    var pt = new System.Globalization.CultureInfo("pt-PT");
}

<div class="d-flex flex-wrap justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0"><i class="fa-solid fa-receipt text-primary"></i> Despesas</h1>
    <div class="d-flex gap-2">
        <a class="btn btn-primary" asp-action="Create"><i class="fa-solid fa-plus"></i> Nova despesa</a>
    </div>
</div>

<form method="get" class="card border-0 shadow-sm mb-3">
    <div class="card-body row g-2 align-items-end">
        <div class="col-md-3">
            <label class="form-label small">Pesquisar</label>
            <input type="text" name="Query" value="@Model.Filter.Query" class="form-control" placeholder="Descrição ou notas..." />
        </div>
        <div class="col-md-2">
            <label class="form-label small">Categoria</label>
            <select name="CategoryId" class="form-select">
                <option value="">Todas</option>
                @foreach (var c in Model.Categories)
                {
                    if (Model.Filter.CategoryId == c.Id)
                    {
                        <option value="@c.Id" selected>@c.Name</option>
                    }
                    else
                    {
                        <option value="@c.Id">@c.Name</option>
                    }
                }
            </select>
        </div>
        <div class="col-md-2">
            <label class="form-label small">Método</label>
            <select name="PaymentMethod" class="form-select">
                <option value="">Todos</option>
                @foreach (var pm in Enum.GetValues<FinSightPro.Domain.Enums.PaymentMethod>())
                {
                    if (Model.Filter.PaymentMethod == pm)
                    {
                        <option value="@pm" selected>@pm</option>
                    }
                    else
                    {
                        <option value="@pm">@pm</option>
                    }
                }
            </select>
        </div>
        <div class="col-md-2">
            <label class="form-label small">De</label>
            <input type="date" name="From" value="@(Model.Filter.From?.ToString("yyyy-MM-dd"))" class="form-control" />
        </div>
        <div class="col-md-2">
            <label class="form-label small">Até</label>
            <input type="date" name="To" value="@(Model.Filter.To?.ToString("yyyy-MM-dd"))" class="form-control" />
        </div>
        <div class="col-md-1">
            <label class="form-label small">Min €</label>
            <input type="number" step="0.01" name="MinAmount" value="@(Model.Filter.MinAmount)" class="form-control" />
        </div>
        <div class="col-md-1">
            <label class="form-label small">Max €</label>
            <input type="number" step="0.01" name="MaxAmount" value="@(Model.Filter.MaxAmount)" class="form-control" />
        </div>
        <div class="col-md-12 d-flex justify-content-end gap-2">
            <button type="submit" class="btn btn-outline-primary"><i class="fa-solid fa-filter"></i> Filtrar</button>
            <a asp-action="Index" class="btn btn-outline-secondary"><i class="fa-solid fa-xmark"></i> Limpar</a>
        </div>
    </div>
</form>

<div class="d-flex justify-content-end gap-2 mb-3">
    <form method="post" asp-action="ExportarCsv" class="d-inline">
        @Html.AntiForgeryToken()
        @Html.Hidden("CategoryId", Model.Filter.CategoryId)
        @Html.Hidden("PaymentMethod", Model.Filter.PaymentMethod)
        @Html.Hidden("From", Model.Filter.From?.ToString("yyyy-MM-dd"))
        @Html.Hidden("To", Model.Filter.To?.ToString("yyyy-MM-dd"))
        @Html.Hidden("Query", Model.Filter.Query)
        @Html.Hidden("MinAmount", Model.Filter.MinAmount)
        @Html.Hidden("MaxAmount", Model.Filter.MaxAmount)
        <button class="btn btn-outline-success btn-sm"><i class="fa-solid fa-file-csv"></i> Exportar CSV</button>
    </form>
    <form method="post" asp-action="ExportarExcel" class="d-inline">
        @Html.AntiForgeryToken()
        @Html.Hidden("CategoryId", Model.Filter.CategoryId)
        @Html.Hidden("PaymentMethod", Model.Filter.PaymentMethod)
        @Html.Hidden("From", Model.Filter.From?.ToString("yyyy-MM-dd"))
        @Html.Hidden("To", Model.Filter.To?.ToString("yyyy-MM-dd"))
        @Html.Hidden("Query", Model.Filter.Query)
        @Html.Hidden("MinAmount", Model.Filter.MinAmount)
        @Html.Hidden("MaxAmount", Model.Filter.MaxAmount)
        <button class="btn btn-outline-success btn-sm"><i class="fa-solid fa-file-excel"></i> Exportar Excel</button>
    </form>
</div>

<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover mb-0 align-middle">
            <thead class="table-light">
                <tr>
                    <th>Data</th>
                    <th>Descrição</th>
                    <th>Categoria</th>
                    <th>Método</th>
                    <th class="text-end">Valor</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var e in Model.Page.Items)
                {
                    <tr>
                        <td>@e.Date.ToString("yyyy-MM-dd")</td>
                        <td>
                            @e.Description
                            @if (e.IsRecurring)
                            {
                                <span class="badge bg-info ms-1"><i class="fa-solid fa-repeat"></i></span>
                            }
                        </td>
                        <td><i class="fa-solid @(e.CategoryIcon ?? "fa-tag")" style="color:@(e.CategoryColor ?? "#6c757d")"></i> @e.CategoryName</td>
                        <td><span class="badge bg-light text-dark">@e.PaymentMethod</span></td>
                        <td class="text-end fw-semibold">@e.Amount.ToString("C", pt)</td>
                        <td class="text-end">
                            <a asp-action="Details" asp-route-id="@e.Id" class="btn btn-sm btn-outline-secondary"><i class="fa-solid fa-eye"></i></a>
                            <a asp-action="Edit" asp-route-id="@e.Id" class="btn btn-sm btn-outline-primary"><i class="fa-solid fa-pen"></i></a>
                            <a asp-action="Delete" asp-route-id="@e.Id" class="btn btn-sm btn-outline-danger"><i class="fa-solid fa-trash"></i></a>
                        </td>
                    </tr>
                }
                @if (!Model.Page.Items.Any())
                {
                    <tr><td colspan="6" class="text-center text-muted py-4">Não foram encontradas despesas.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>

@if (Model.Page.TotalPages > 1)
{
    <nav class="mt-3">
        <ul class="pagination justify-content-center">
            <li class="page-item @(Model.Page.HasPrevious ? "" : "disabled")">
                <a class="page-link" href="?page=@(Model.Page.Page - 1)&CategoryId=@Model.Filter.CategoryId&Query=@Model.Filter.Query">‹</a>
            </li>
            @for (int i = 1; i <= Model.Page.TotalPages; i++)
            {
                <li class="page-item @(i == Model.Page.Page ? "active" : "")">
                    <a class="page-link" href="?page=@i&CategoryId=@Model.Filter.CategoryId&Query=@Model.Filter.Query">@i</a>
                </li>
            }
            <li class="page-item @(Model.Page.HasNext ? "" : "disabled")">
                <a class="page-link" href="?page=@(Model.Page.Page + 1)&CategoryId=@Model.Filter.CategoryId&Query=@Model.Filter.Query">›</a>
            </li>
        </ul>
    </nav>
}
