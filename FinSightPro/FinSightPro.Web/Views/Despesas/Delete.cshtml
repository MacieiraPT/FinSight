@model FinSightPro.Application.DTOs.ExpenseDto
@{
    ViewData["Title"] = "Eliminar Despesa";
    var pt = new System.Globalization.CultureInfo("pt-PT");
}

<div class="card border-0 shadow-sm">
    <div class="card-body">
        <h1 class="h4 mb-3 text-danger"><i class="fa-solid fa-triangle-exclamation"></i> Eliminar despesa</h1>
        <p>Tens a certeza que pretendes eliminar a despesa abaixo? Esta ação é irreversível.</p>
        <ul class="list-unstyled small mb-0">
            <li><strong>Descrição:</strong> @Model.Description</li>
            <li><strong>Valor:</strong> @Model.Amount.ToString("C", pt)</li>
            <li><strong>Data:</strong> @Model.Date.ToString("yyyy-MM-dd")</li>
            <li><strong>Categoria:</strong> @Model.CategoryName</li>
        </ul>
    </div>
    <div class="card-footer bg-transparent d-flex justify-content-end gap-2">
        <form asp-action="Delete" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.Id" />
            <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
            <button type="submit" class="btn btn-danger"><i class="fa-solid fa-trash"></i> Eliminar</button>
        </form>
    </div>
</div>
