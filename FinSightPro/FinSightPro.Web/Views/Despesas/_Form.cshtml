@model FinSightPro.Web.ViewModels.ExpenseFormViewModel

<div class="row g-3">
    <div class="col-md-8">
        <label asp-for="Description" class="form-label"></label>
        <input asp-for="Description" class="form-control" />
        <span asp-validation-for="Description" class="text-danger small"></span>
    </div>
    <div class="col-md-4">
        <label asp-for="Amount" class="form-label"></label>
        <input asp-for="Amount" type="number" step="0.01" class="form-control" />
        <span asp-validation-for="Amount" class="text-danger small"></span>
    </div>
    <div class="col-md-4">
        <label asp-for="Date" class="form-label"></label>
        <input asp-for="Date" type="date" class="form-control" value="@Model.Date.ToString("yyyy-MM-dd")" />
        <span asp-validation-for="Date" class="text-danger small"></span>
    </div>
    <div class="col-md-4">
        <label asp-for="CategoryId" class="form-label"></label>
        <select asp-for="CategoryId" class="form-select">
            <option value="">— escolher —</option>
            @foreach (var c in Model.Categories)
            {
                <option value="@c.Id">@c.Name</option>
            }
        </select>
        <span asp-validation-for="CategoryId" class="text-danger small"></span>
    </div>
    <div class="col-md-4">
        <label asp-for="PaymentMethod" class="form-label"></label>
        <select asp-for="PaymentMethod" class="form-select">
            @foreach (var pm in Enum.GetValues<FinSightPro.Domain.Enums.PaymentMethod>())
            {
                <option value="@pm">@pm</option>
            }
        </select>
    </div>
    <div class="col-md-12">
        <label asp-for="Notes" class="form-label"></label>
        <textarea asp-for="Notes" class="form-control" rows="2"></textarea>
    </div>
    <div class="col-md-6">
        <label asp-for="Attachment" class="form-label"></label>
        <input asp-for="Attachment" type="file" class="form-control" accept=".pdf,.png,.jpg,.jpeg,.webp" />
        @if (!string.IsNullOrEmpty(Model.ExistingAttachmentPath))
        {
            <div class="form-text">
                <a href="@Model.ExistingAttachmentPath" target="_blank"><i class="fa-solid fa-paperclip"></i> Comprovativo atual</a>
            </div>
        }
    </div>
    <div class="col-md-6">
        <div class="form-check mt-4">
            <input asp-for="IsRecurring" class="form-check-input" />
            <label class="form-check-label" asp-for="IsRecurring"></label>
        </div>
    </div>
    <div class="col-md-4 recurring-only">
        <label asp-for="RecurrenceType" class="form-label"></label>
        <select asp-for="RecurrenceType" class="form-select">
            @foreach (var r in Enum.GetValues<FinSightPro.Domain.Enums.RecurrenceType>())
            {
                if (r != FinSightPro.Domain.Enums.RecurrenceType.None)
                {
                    <option value="@r">@r</option>
                }
            }
        </select>
    </div>
    <div class="col-md-4 recurring-only">
        <label asp-for="RecurrenceEndDate" class="form-label"></label>
        <input asp-for="RecurrenceEndDate" type="date" class="form-control" />
    </div>
</div>
