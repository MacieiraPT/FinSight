@model GestaoDespesas.Models.Orcamento

@{
    ViewData["Title"] = "Detalhes do orçamento";
}

<div class="d-flex justify-content-between align-items-start mb-4">
    <div>
        <div class="text-muted">Informação completa do orçamento.</div>
    </div>

    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.OrcamentoId"
           class="btn btn-outline-secondary">Editar</a>

        <a asp-action="Index"
           class="btn btn-outline-secondary">Voltar</a>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body">

        <div class="row mb-3">
            <div class="col-sm-3 text-muted">Categoria</div>
            <div class="col-sm-9 fw-semibold">@Model.Categoria?.Nome</div>
        </div>

        <div class="row mb-3">
            <div class="col-sm-3 text-muted">Mês</div>
            <div class="col-sm-9">
                @(new System.Globalization.CultureInfo("pt-PT").DateTimeFormat.GetMonthName(Model.Mes))
                @Model.Ano
            </div>
        </div>

        <div class="row mb-3">
            <div class="col-sm-3 text-muted">Limite</div>
            <div class="col-sm-9 fw-semibold">@Model.Limite.ToString("C")</div>
        </div>

    </div>
</div>
