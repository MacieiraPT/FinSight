@model GestaoDespesas.Models.Orcamento

@{
    ViewData["Title"] = "Eliminar orçamento";
}

<div class="card border-danger shadow-sm">
    <div class="card-body">
        <p>Tens a certeza que queres eliminar este orçamento?</p>

        <dl class="row mb-3">
            <dt class="col-sm-3 text-muted">Categoria</dt>
            <dd class="col-sm-9">@Model.Categoria?.Nome</dd>

            <dt class="col-sm-3 text-muted">Mês</dt>
            <dd class="col-sm-9">
                @(new System.Globalization.CultureInfo("pt-PT").DateTimeFormat.GetMonthName(Model.Mes))
                @Model.Ano
            </dd>

            <dt class="col-sm-3 text-muted">Limite</dt>
            <dd class="col-sm-9">@Model.Limite.ToString("C")</dd>
        </dl>

        <form asp-action="Delete">
            <input type="hidden" asp-for="OrcamentoId" />
            <button type="submit" class="btn btn-danger">Eliminar</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
        </form>
    </div>
</div>
