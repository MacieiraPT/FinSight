@model GestaoDespesas.Models.Receita

@{
    ViewData["Title"] = "Detalhes da receita";
}

<div class="d-flex justify-content-between align-items-start mb-4">
    <div>
        <div class="text-muted">Informação completa da receita.</div>
    </div>

    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.ReceitaId"
           class="btn btn-outline-secondary">Editar</a>

        <a asp-action="Index"
           class="btn btn-outline-secondary">Voltar</a>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body">

        <div class="row mb-3">
            <div class="col-sm-3 text-muted">Descrição</div>
            <div class="col-sm-9 fw-semibold">@Model.Descricao</div>
        </div>

        <div class="row mb-3">
            <div class="col-sm-3 text-muted">Tipo</div>
            <div class="col-sm-9">@Model.Tipo</div>
        </div>

        <div class="row mb-3">
            <div class="col-sm-3 text-muted">Data</div>
            <div class="col-sm-9">@Model.Data.ToString("dd/MM/yyyy")</div>
        </div>

        <div class="row mb-3">
            <div class="col-sm-3 text-muted">Valor</div>
            <div class="col-sm-9 fw-semibold">
                @Model.Valor.ToString("C")
            </div>
        </div>

    </div>
</div>
