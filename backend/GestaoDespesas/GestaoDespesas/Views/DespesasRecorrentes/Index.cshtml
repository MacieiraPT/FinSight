@model IEnumerable<GestaoDespesas.Models.DespesaRecorrente>

@{
    ViewData["Title"] = "Despesas Recorrentes";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <div class="text-muted">Gere despesas que se repetem automaticamente.</div>
    </div>
    <a asp-action="Create" class="btn btn-primary">
        Nova recorrente
    </a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">
        Ainda não tens despesas recorrentes definidas.
    </div>
}
else
{
    <table class="table align-middle">
        <thead>
            <tr>
                <th>Descrição</th>
                <th>Categoria</th>
                <th>Frequência</th>
                <th>Início</th>
                <th class="text-end">Valor</th>
                <th class="text-center">Estado</th>
                <th class="text-end" style="width:220px;">Ações</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr class="@(!item.Ativa ? "opacity-50" : "")">
                    <td class="fw-semibold">@item.Descricao</td>
                    <td>@item.Categoria?.Nome</td>
                    <td>@item.Frequencia</td>
                    <td>@item.DataInicio.ToString("dd/MM/yyyy")</td>
                    <td class="text-end fw-semibold">@item.Valor.ToString("C")</td>
                    <td class="text-center">
                        @if (item.Ativa)
                        {
                            <span class="badge bg-success">Ativa</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Inativa</span>
                        }
                    </td>
                    <td class="text-end">
                        <a asp-action="Edit" asp-route-id="@item.DespesaRecorrenteId"
                           class="btn btn-sm btn-outline-secondary">Editar</a>
                        <a asp-action="Delete" asp-route-id="@item.DespesaRecorrenteId"
                           class="btn btn-sm btn-outline-danger">Apagar</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
