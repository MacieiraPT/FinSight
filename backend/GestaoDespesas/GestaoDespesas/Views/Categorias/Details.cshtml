@model GestaoDespesas.Models.Categoria

@{
    ViewData["Title"] = "Detalhes da categoria";
}

<div class="d-flex justify-content-between align-items-start mb-4">
    <div>
        <div class="text-muted">Informação completa da categoria selecionada.</div>
    </div>

    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.CategoriaId"
           class="btn btn-outline-secondary">
            Editar
        </a>

        <a asp-action="Index"
           class="btn btn-outline-secondary">
            Voltar
        </a>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <div class="row mb-3">
            <div class="col-sm-3 text-muted">Ícone</div>
            <div class="col-sm-9">
                <span class="cat-chip" style="background-color:@Model.Cor">
                    <i class="bi @Model.Icone"></i>
                </span>
                <code class="ms-2 small">@Model.Icone</code>
            </div>
        </div>

        <div class="row mb-3">
            <div class="col-sm-3 text-muted">Nome</div>
            <div class="col-sm-9 fw-semibold">@Model.Nome</div>
        </div>

        <div class="row mb-3">
            <div class="col-sm-3 text-muted">Cor</div>
            <div class="col-sm-9">
                <span class="d-inline-block rounded" style="width:1.4rem;height:1.4rem;background:@Model.Cor;vertical-align:middle"></span>
                <code class="ms-2 small">@Model.Cor</code>
            </div>
        </div>

        @if (Model.CategoriaPai != null)
        {
            <div class="row mb-3">
                <div class="col-sm-3 text-muted">Categoria-pai</div>
                <div class="col-sm-9">@Model.CategoriaPai.Nome</div>
            </div>
        }
    </div>
</div>
