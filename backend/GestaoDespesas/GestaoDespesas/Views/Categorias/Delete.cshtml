@model GestaoDespesas.Models.Categoria

@{
    ViewData["Title"] = "Eliminar categoria";
}

<div class="card border-danger">
    <div class="card-body">
        <p>Tens a certeza que queres eliminar esta categoria?</p>

        <div class="d-flex align-items-center gap-2 fw-semibold mb-3">
            <span class="cat-chip" style="background-color:@Model.Cor">
                <i class="bi @Model.Icone"></i>
            </span>
            @Model.Nome
            @if (Model.CategoriaPai != null)
            {
                <small class="text-muted">↳ @Model.CategoriaPai.Nome</small>
            }
        </div>

        <form asp-action="Delete">
            <input type="hidden" asp-for="CategoriaId" />
            <button type="submit" class="btn btn-danger">Eliminar</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
        </form>
    </div>
</div>
