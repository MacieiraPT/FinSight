@using System.Globalization
@{
    ViewData["Title"] = "Dashboard";
    var totalMes = (decimal)ViewBag.TotalMes;
    var totalMesAnterior = (decimal)ViewBag.TotalMesAnterior;
    var variacaoMoM = (decimal)ViewBag.VariacaoMoM;
    var totalReceitasMes = (decimal)ViewBag.TotalReceitasMes;
    var saldoMes = (decimal)ViewBag.SaldoMes;
    var taxaPoupanca = (decimal)ViewBag.TaxaPoupanca;
    var projecaoMes = (decimal)ViewBag.ProjecaoMes;
    var mediaDiaria = (decimal)ViewBag.MediaDiaria;
    var diasNoMes = (int)ViewBag.DiasNoMes;
    var diasDecorridos = (int)ViewBag.DiasDecorridos;
    var categorias = ViewBag.Categorias;
    var top5 = ViewBag.Top5 as IEnumerable<dynamic>;
    var ptCulture = new CultureInfo("pt-PT");
}

@if (ViewBag.AlertaGrave == true)
{
    <div class="alert alert-danger text-center">
        <i class="bi bi-exclamation-octagon-fill"></i>
        Ultrapassaste o limite mensal definido com base @(ViewBag.UsaReceitasReais == true ? "nas tuas receitas reais" : "no teu salário")!
    </div>
}
else if (ViewBag.Alerta == true)
{
    <div class="alert alert-warning text-center">
        <i class="bi bi-exclamation-triangle-fill"></i>
        Estás perto de atingir o limite mensal baseado @(ViewBag.UsaReceitasReais == true ? "nas tuas receitas reais" : "no teu salário").
    </div>
}

@if (ViewBag.Progresso != null)
{
    foreach (var o in ViewBag.Progresso)
    {
        var percent = o.Limite > 0 ? (o.TotalGasto / o.Limite) * 100 : 0;

        if (percent > 100)
        {
            <div class="alert alert-danger text-center">
                <i class="bi bi-exclamation-octagon-fill"></i>
                Ultrapassaste um orçamento este mês.
            </div>
            break;
        }
        else if (percent > 80)
        {
            <div class="alert alert-warning text-center">
                <i class="bi bi-exclamation-triangle-fill"></i>
                Atenção: estás perto de atingir um orçamento.
            </div>
            break;
        }
    }
}

<div class="row g-4 mb-2 justify-content-center">

    <!-- RECEITAS -->
    <div class="col-lg-4 col-md-6">
        <div class="card shadow-sm border-0 p-4 dashboard-card h-100 text-center">
            <div class="text-muted mb-1">Receitas este mês</div>

            <div class="display-5 fw-bold text-success lh-1">
                @totalReceitasMes.ToString("C", ptCulture)
            </div>

            <div class="small text-muted mt-1">
                Total de entradas registadas
            </div>
        </div>
    </div>

    <!-- DESPESAS -->
    <div class="col-lg-4 col-md-6">
        <div class="card shadow-sm border-0 p-4 dashboard-card h-100 text-center">
            <div class="text-muted mb-1">Despesas este mês</div>

            <div class="display-5 fw-bold text-primary lh-1">
                @totalMes.ToString("C", ptCulture)
            </div>

            @if (totalMesAnterior > 0)
            {
                var setaCls = variacaoMoM > 0 ? "text-danger" : (variacaoMoM < 0 ? "text-success" : "text-muted");
                var seta = variacaoMoM > 0 ? "↑" : (variacaoMoM < 0 ? "↓" : "→");
                <div class="small @setaCls mt-1">
                    @seta @(variacaoMoM > 0 ? "+" : "")@variacaoMoM.ToString("0.#")% vs mês anterior
                </div>
            }
            else
            {
                <div class="small text-muted mt-1">Total de saídas registadas</div>
            }
        </div>
    </div>

    <!-- SALDO -->
    <div class="col-lg-4 col-md-6">
        <div class="card shadow-sm border-0 p-4 dashboard-card h-100 text-center">
            <div class="text-muted mb-1">Saldo mensal</div>

            <div class="display-5 fw-bold @(saldoMes >= 0 ? "text-success" : "text-danger") lh-1">
                @saldoMes.ToString("C", ptCulture)
            </div>

            <div class="small text-muted mt-1">
                Receitas − Despesas
            </div>
        </div>
    </div>

</div>

<!-- KPIs avançados: poupança + projeção + top 5 -->
<div class="row g-4 mb-2 mt-1">
    <div class="col-md-4">
        <div class="card shadow-sm border-0 p-4 dashboard-card h-100">
            <div class="text-muted mb-1">Taxa de poupança</div>
            <div class="display-6 fw-bold @(taxaPoupanca >= 0 ? "text-success" : "text-danger") lh-1">
                @taxaPoupanca.ToString("0.#")%
            </div>
            <div class="small text-muted mt-1">
                Saldo / Receitas do mês
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card shadow-sm border-0 p-4 dashboard-card h-100">
            <div class="text-muted mb-1">Projeção até fim do mês</div>
            <div class="display-6 fw-bold text-primary lh-1">
                @projecaoMes.ToString("C", ptCulture)
            </div>
            <div class="small text-muted mt-1">
                Média diária @mediaDiaria.ToString("C", ptCulture) · @diasDecorridos / @diasNoMes dias
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card shadow-sm border-0 p-4 dashboard-card h-100">
            <div class="text-muted mb-2">Top 5 categorias</div>
            @if (top5 != null && top5.Any())
            {
                <ul class="list-unstyled mb-0 small">
                    @foreach (var c in top5)
                    {
                        <li class="d-flex justify-content-between align-items-center py-1">
                            <span class="d-inline-flex align-items-center gap-2">
                                <span class="cat-chip-sm" style="background-color:@c.Cor">
                                    <i class="bi @c.Icone"></i>
                                </span>
                                @c.Categoria
                            </span>
                            <strong>@(((decimal)c.Total).ToString("C", ptCulture))</strong>
                        </li>
                    }
                </ul>
            }
            else
            {
                <div class="text-muted small">Sem despesas este mês.</div>
            }
        </div>
    </div>
</div>

<!-- LIMITE -->
<div class="row g-4 mb-2 justify-content-center mt-1">
    <div class="col-lg-8 col-md-10">
        <div class="card shadow-sm border-0 p-4 dashboard-card h-100 text-center">

            <small class="text-muted d-block mb-2">
                Limite mensal de despesas
                @if (ViewBag.UsaReceitasReais == true)
                {
                    <span class="badge bg-success bg-opacity-25 text-success ms-1">baseado em receitas reais</span>
                }
            </small>

            @if (ViewBag.LimitePermitido > 0)
            {
                var limite = (decimal)ViewBag.LimitePermitido;
                var restante = limite - totalMes;
                var percent = limite > 0 ? (totalMes / limite) * 100 : 0;

                <div class="display-6 fw-bold
            @(percent >= 100 ? "text-danger" :
                                                percent >= 80 ? "text-warning" : "text-success")">

                    @(percent >= 100
                                    ? $"Excedeste o limite em {Math.Abs(restante).ToString("C", ptCulture)}"
                                    : $"Restam {restante.ToString("C", ptCulture)}")
                </div>

                <small class="text-muted d-block mt-1">
                    @percent.ToString("0")% do limite usado
                </small>

                var percentWidth = percent.ToString("0.##", CultureInfo.InvariantCulture);

                <div class="progress mt-2" style="height:6px;">
                    <div class="progress-bar
            @(percent >= 100 ? "bg-danger" :
                                   percent >= 80 ? "bg-warning" : "bg-success")"
                         style="width:@(percentWidth)%;">
                    </div>
                </div>
            }
            else
            {
                <div class="text-muted">
                    Adiciona receitas ou define o salário nas configurações
                </div>
            }

        </div>
    </div>
</div>

<div class="row mt-3 g-4">

    <!-- Doughnut -->
    <div class="col-lg-6">
        <div class="card shadow-sm border-0 p-4 dashboard-card h-100">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="mb-0">Distribuição por categoria</h5>
                <span class="badge bg-light text-dark">Este mês</span>
            </div>

            <div class="chart-container doughnut-chart">
                <canvas id="graficoCategorias"></canvas>
            </div>
        </div>
    </div>

    <!-- Linha -->
    <div class="col-lg-6">
        <div class="card shadow-sm border-0 p-4 dashboard-card h-100">
            <h5 class="mb-3">Últimos 6 meses</h5>

            <div class="chart-container line-chart">
                <canvas id="grafico6Meses"></canvas>
            </div>
        </div>
    </div>

</div>

@if (ViewBag.Progresso != null)
{
    <div class="card shadow-sm border-0 p-4 dashboard-card mt-5">

        <h5 class="mb-4">Orçamentos deste mês</h5>

        @foreach (var o in ViewBag.Progresso)
        {
            var rawPercent = o.Limite > 0 ? (o.TotalGasto / o.Limite) * 100 : 0;
            var percent = Math.Min(rawPercent, 100);

            string cor = rawPercent >= 100 ? "bg-danger"
            : rawPercent >= 80 ? "bg-warning"
            : "bg-success";

            <div class="mb-3">

                <div class="d-flex justify-content-between">
                    <strong class="d-inline-flex align-items-center gap-2">
                        @if (o.Cor != null && o.Icone != null)
                        {
                            <span class="cat-chip-sm" style="background-color:@o.Cor">
                                <i class="bi @o.Icone"></i>
                            </span>
                        }
                        @o.Categoria
                    </strong>
                    <span>@percent.ToString("0")%</span>
                </div>

                <div class="progress mt-2" style="height:8px;">
                    <div class="progress-bar @cor"
                         role="progressbar"
                         style="width:@percent.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)%">
                    </div>
                </div>

                <small class="text-muted">
                    @o.TotalGasto.ToString("C") de @o.Limite.ToString("C")
                </small>

            </div>
        }

    </div>
}

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>

    const chartColors = window.gdGetChartColors();

    Chart.defaults.color = chartColors.text;
    Chart.defaults.borderColor = chartColors.grid;

    const categorias = JSON.parse('@Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.Categorias))');
    const seisMeses = JSON.parse('@Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.SeisMeses))');

    const labels = categorias.map(c => c.Categoria);
    const valores = categorias.map(c => c.Total);

    const labels6 = seisMeses.map(m => m.Mes);
    const valores6 = seisMeses.map(m => m.Total);
    const receitas6 = seisMeses.map(m => m.TotalReceitas);

    const total = valores.reduce((a, b) => a + b, 0);

    function gerarCoresFallback(n) {
        const cores = [];
        for (let i = 0; i < n; i++) {
            const hue = Math.floor((360 / n) * i);
            cores.push(`hsl(${hue}, 65%, 60%)`);
        }
        return cores;
    }

    // Usar a cor real da categoria sempre que disponível, com fallback HSL
    const fallback = gerarCoresFallback(valores.length);
    const cores = categorias.map((c, i) => (c.Cor && c.Cor.length > 0) ? c.Cor : fallback[i]);

    new Chart(document.getElementById('graficoCategorias'), {
        type: 'doughnut',
        data: {
            labels: labels,
            datasets: [{
                data: valores,
                backgroundColor: cores,
                borderWidth: 0,
                hoverOffset: 12
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            cutout: '65%',
            plugins: {
                legend: {
                    position: 'bottom',
                    labels: {
                        color: chartColors.text,
                        usePointStyle: true,
                        padding: 20
                    }
                },
                tooltip: {
                    backgroundColor: chartColors.tooltipBg,
                    titleColor: chartColors.text,
                    bodyColor: chartColors.text,
                    borderColor: chartColors.grid,
                    borderWidth: 1,
                    callbacks: {
                        label: function(context) {
                            const value = context.parsed;
                            const percent = ((value / total) * 100).toFixed(1);
                            return `${context.label}: ${value.toLocaleString('pt-PT', {style:'currency', currency:'EUR'})} (${percent}%)`;
                        }
                    }
                }
            }
        }
    });

    new Chart(document.getElementById('grafico6Meses'), {
        type: 'line',
        data: {
            labels: labels6,
            datasets: [
                {
                    label: 'Receitas',
                    data: receitas6,
                    borderColor: '#10b981',
                    backgroundColor: 'rgba(16,185,129,0.12)',
                    fill: 'start',
                    tension: 0.4
                },
                {
                    label: 'Despesas',
                    data: valores6,
                    borderColor: '#6366f1',
                    backgroundColor: 'rgba(99,102,241,0.12)',
                    fill: 'start',
                    tension: 0.4
                }
            ]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
                legend: {
                    labels: {
                        color: chartColors.text
                    }
                },
                tooltip: {
                    backgroundColor: chartColors.tooltipBg,
                    titleColor: chartColors.text,
                    bodyColor: chartColors.text,
                    borderColor: chartColors.grid,
                    borderWidth: 1
                }
            },
            scales: {
                x: {
                    ticks: { color: chartColors.text },
                    grid: { color: chartColors.grid }
                },
                y: {
                    ticks: { color: chartColors.text },
                    grid: { color: chartColors.grid }
                }
            }
        }
    });

</script>
}
